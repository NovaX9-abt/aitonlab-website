# HOW TO DEPLOY TO VERCEL WITH SUPABASE
# 1. Create a Supabase project at https://supabase.com
# 2. Get your Project URL and anon key from Project Settings > API
# 3. Create a table 'contact_submissions' with columns:
#    - id (uuid, primary key)
#    - created_at (timestamp)
#    - name (text)
#    - business_name (text)
#    - email (text)
#    - whatsapp (text)
#    - service (text)
#    - details (text)
#    - consent (boolean)
# 4. Integrate with Google Sheets via Make.com/Zapier matching rows to 'contact_submissions' inserts
# 5. In Vercel, go to Settings > Environment Variables, and add the two VITE_ variables above.

# Riley Voice Agent WebSocket URL
# Local development: ws://localhost:8000/ws
# Production: wss://riley.aitonlab.rw/ws
VITE_RILEY_WS_URL=ws://localhost:8000/ws
